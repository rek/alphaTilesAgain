{
  "name": "data-language-assets",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/alphaTiles/data-language-assets/src",
  "projectType": "library",
  "tags": ["type:data-access", "scope:alphaTiles"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/alphaTiles/data-language-assets",
        "main": "libs/alphaTiles/data-language-assets/src/index.ts",
        "tsConfig": "libs/alphaTiles/data-language-assets/tsconfig.lib.json",
        "assets": ["libs/alphaTiles/data-language-assets/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/alphaTiles/data-language-assets/jest.config.ts"
      }
    }
  }
}
