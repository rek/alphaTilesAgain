{
  "name": "alphaTiles",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/alphaTiles/src",
  "projectType": "application",
  "tags": ["scope:alphaTiles", "type:app"],
  "targets": {
    "start": {
      "executor": "@nx/expo:start",
      "continuous": true,
      "dependsOn": ["prebuild-lang"],
      "options": {
        "port": 8081
      }
    },
    "prebuild": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx expo prebuild --clean",
        "cwd": "apps/alphaTiles"
      }
    },
    "run-android": {
      "executor": "@nx/expo:run",
      "dependsOn": ["prebuild-lang"],
      "options": {
        "platform": "android"
      }
    },
    "run-ios": {
      "executor": "@nx/expo:run",
      "dependsOn": ["prebuild-lang"],
      "options": {
        "platform": "ios"
      }
    },
    "buildApk": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "cd apps/alphaTiles/android && ./gradlew assembleRelease --warning-mode=all",
            "description": "Build release APK"
          },
          {
            "command": "mkdir -p dist/apps/alphaTiles",
            "description": "Create dist directory"
          },
          {
            "command": "cp apps/alphaTiles/android/app/build/outputs/apk/release/app-release.apk dist/apps/alphaTiles/alphaTiles-release.apk",
            "description": "Copy APK to dist"
          }
        ],
        "parallel": false
      },
      "outputs": ["{workspaceRoot}/dist/apps/alphaTiles"]
    },
    "web-export": {
      "executor": "nx:run-commands",
      "dependsOn": ["prebuild-lang"],
      "outputs": ["{workspaceRoot}/dist/web/alpha-tiles"],
      "options": {
        "command": "npx expo export --platform web --output-dir dist/web && mkdir -p ../../dist/web/alpha-tiles && cp -r dist/web/. ../../dist/web/alpha-tiles/",
        "cwd": "apps/alphaTiles"
      }
    },
    "rsync-lang-pack": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx tools/rsync-lang-packs.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "validate-lang-pack": {
      "executor": "nx:run-commands",
      "dependsOn": ["rsync-lang-pack"],
      "options": {
        "command": "npx tsx tools/validate-lang-pack.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "generate-lang-manifest": {
      "executor": "nx:run-commands",
      "dependsOn": ["validate-lang-pack"],
      "options": {
        "command": "npx tsx tools/generate-lang-manifest.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "prebuild-lang": {
      "executor": "nx:noop"
    },
    "start-web-eng": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "APP_LANG=eng npx tsx tools/generate-lang-manifest.ts && cd apps/alphaTiles && APP_LANG=eng npx expo start -w --port 8081",
        "cwd": "{workspaceRoot}"
      }
    },
    "start-web-yue": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "APP_LANG=yue npx tsx tools/generate-lang-manifest.ts && cd apps/alphaTiles && APP_LANG=yue npx expo start -w --port 8081",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
