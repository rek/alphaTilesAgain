{
  "name": "feature-about",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/alphaTiles/feature-about/src",
  "projectType": "library",
  "tags": ["type:feature", "scope:alphaTiles"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/alphaTiles/feature-about",
        "main": "libs/alphaTiles/feature-about/src/index.ts",
        "tsConfig": "libs/alphaTiles/feature-about/tsconfig.lib.json",
        "assets": ["libs/alphaTiles/feature-about/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/alphaTiles/feature-about/jest.config.ts"
      }
    }
  }
}
